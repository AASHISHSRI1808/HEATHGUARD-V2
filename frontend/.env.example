# HealthGuard Frontend — Environment Variables
# Copy this file to .env and fill in your values

# Backend API base URL
REACT_APP_API_URL=http://localhost:5000/api

# Razorpay PUBLIC key (safe to expose in frontend — starts with rzp_test_)
# Get it from: https://dashboard.razorpay.com → Settings → API Keys
REACT_APP_RAZORPAY_KEY=rzp_test_XXXXXXXXXXXXXXXX
